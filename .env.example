# Environment Configuration
# Copy this file to .env and fill in the values.
# The application works without email configuration; only the contact form
# email delivery will be unavailable if SMTP settings are omitted.

ENVIRONMENT=development

# Security
# Generate a strong random key for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Admin Access for Data Updates
# Used as the X-Admin-Key header value for POST /api/admin/update-base-data
ADMIN_UPDATE_KEY=admin-secret-key-change-in-production

# Database (if you add one later)
# DATABASE_URL=postgresql://user:password@localhost/pulse_of_korea

# Email Configuration (optional — required only for contact form email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# Note: For Gmail, use an App Password instead of your regular password
# https://support.google.com/accounts/answer/185833

# External API Keys (if needed)
# KOSIS_API_KEY=your-kosis-api-key
# CIA_API_KEY=your-cia-api-key

# Monitoring (if you add services like Sentry)
# SENTRY_DSN=your-sentry-dsn
